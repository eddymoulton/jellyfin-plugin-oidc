# The Jellyfin server image the integration tests run against.
# This is the latest version we validate the plugin on.
JELLYFIN_VERSION=10.11.11

# The snapshot whose seeded /config the tests boot from.
# This should only need to change if there is a manual migration or breakage between this and JELLYFIN_VERSION.
JELLYFIN_SNAPSHOT_VERSION=10.11.10

# The Dex OIDC provider image used by the tests.
DEX_VERSION=v2.45.1
