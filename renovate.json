  "extends": ["config:recommended", "helpers:pinGitHubActionDigests"],
  "semanticCommits": "enabled",
  "packageRules": [
    {
      "matchManagers": ["nuget"],
      "matchPackageNames": ["Jellyfin.Controller", "Jellyfin.Model"],
      "groupName": "Jellyfin packages"
    }
  ]
}
